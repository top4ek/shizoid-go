runtime:
  app_env: production
  log_level: info

database:
  host: postgres
  port: "5432"
  name: shizoid
  user: shizoid
  password: changeme

telegram:
  token: "111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  webhook_url: "" # empty = long polling
  webhook_secret_token: ""

sentry:
  dsn: ""
  environment: production
  release: ""

app:
  allow_to_all: false
  bot_owners:
    - 11111111
  bind_to: 8095
  locale: ru
  generation_mode: classic
  winner_cron: "20 4 * * *"
  idle_cron: "40 19 * * *"
  memory_cron: "0 */6 * * *"

