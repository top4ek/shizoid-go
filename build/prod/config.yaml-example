app_env: production
log_level: info

database:
  host: postgres
  port: "5432"
  name: shizoid
  user: shizoid
  password: changeme

telegram:
  token: "111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  webhook_url: "" # empty = long polling
  webhook_secret_token: ""

sentry:
  dsn: ""
  environment: production
  release: ""

app:
  allow_to_all: false
  bot_owners:
    - 11111111
  bind_to: 8095
  locale: ru
  generation_mode: classic
  winner_cron: "20 1 * * *"
  idle_cron: "0 * * * *" # poll hourly; 9:00–21:00 UTC window enforced in code
  # idle_prompt: override the default prompt for daily idle questions
  memory_cron: "0 */6 * * *"

neural:
  reply:
    - name: openrouter
      base_url: https://openrouter.ai/api/v1
      api_key: sk-or-v1-...
      model: "openrouter/free"
      context_size: 32000
      timeout_seconds: 60
      sampling:
        temperature: 0.7
        top_p: 0.8
        top_k: 20
        min_p: 0.0
        presence_penalty: 1.5
        repeat_penalty: 1.0
  summary:
    - name: openrouter
      base_url: https://openrouter.ai/api/v1
      api_key: sk-or-v1-...
      model: "openrouter/free"
      timeout_seconds: 120
    - name: local
      base_url: http://llama:3110/v1
      model: Qwen3-1.7B-Q4_K_M.gguf
      context_size: 8192
      timeout_seconds: 120
      slot_check: true
      sampling:
        temperature: 1.0
        top_p: 0.95
        top_k: 20
        min_p: 0.0
        presence_penalty: 1.5
        repeat_penalty: 1.0
