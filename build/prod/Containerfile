FROM golang:alpine AS builder

WORKDIR /opt

ENV GO111MODULE=on
ENV GOOS=linux
ENV GOARCH=amd64
ENV CGO_ENABLED=0

RUN apk --no-cache --update add ca-certificates git

ARG GIT_COMMIT=unknown

COPY go.mod go.sum ./
RUN go mod download && go mod verify

COPY . .

RUN go build -trimpath \
  -ldflags="-s -w -X shizoid/internal/version.commit=${GIT_COMMIT}" \
  -o /shizoid ./cmd/app

FROM scratch

EXPOSE 8095

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /shizoid /shizoid

CMD ["/shizoid"]
