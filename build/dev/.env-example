# Docker infrastructure only (postgres + llama containers).
# Application settings live in build/dev/config.yaml — see config.yaml-example.

POSTGRES_DB=shizoid
POSTGRES_USER=shizoid
POSTGRES_PASSWORD=changeme

# Local llama.cpp server (LLAMA_ARG_* read by llama-server inside the container).
# Drop the .gguf into ./models on the host. On 8GB/4-core CPU-only:
# Qwen3-1.7B Q4_K_M is the recommended default; for 4B set LLAMA_ARG_MODEL to
# the 4B gguf path, LLAMA_ARG_N_PARALLEL=1, LLAMA_ARG_CTX_SIZE=2048 (slow on CPU).
LLAMA_ARG_MODEL=/models/Qwen3-1.7B-Q4_K_M.gguf
LLAMA_ARG_CTX_SIZE=4096
LLAMA_ARG_N_PARALLEL=3
LLAMA_ARG_THREADS=4
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=3110
# Compose-only (host-side interpolation for mem_limit in docker-compose.yaml).
LLAMA_MEM_LIMIT=4g
