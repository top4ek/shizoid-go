runtime:
  app_env: development
  log_level: info

database:
  host: postgres
  port: "5432"
  name: shizoid
  user: shizoid
  password: changeme

telegram:
  token: "111111111:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  webhook_url: "" # empty = long polling
  webhook_secret_token: ""

sentry:
  dsn: ""
  environment: production
  release: ""

app:
  allow_to_all: false
  bot_owners:
    - 11111111
  bind_to: 3000
  locale: ru
  generation_mode: classic
  winner_cron: "20 4 * * *"
  idle_cron: "40 19 * * *"
  # app_prompt: override the default system prompt for neural replies
  memory_cron: "0 */6 * * *"
  # summary_prompt: override the default memory summarization instructions

# Neural provider fallback chains. Each list is tried top to bottom until a
# provider answers. reply: chat replies (tried before Markov fallback). summary: long-term memory cron.
neural:
  reply:
    - name: openrouter
      base_url: https://openrouter.ai/api/v1
      api_key: sk-or-v1-...
      model: google/gemma-3-4b-it
      context_size: 32000
      timeout_seconds: 60
      daily_limit: 500
    - name: local
      base_url: http://llama:3110/v1
      model: Qwen3-1.7B-Q4_K_M.gguf
      context_size: 8192
      timeout_seconds: 25
      slot_check: true
  summary:
    # - name: openrouter
    #   base_url: https://openrouter.ai/api/v1
    #   api_key: sk-or-v1-...
    #   model: google/gemma-3-4b-it
    #   timeout_seconds: 120
    - name: local
      base_url: http://llama:3110/v1
      model: Qwen3-1.7B-Q4_K_M.gguf
      context_size: 8192
      timeout_seconds: 120
      slot_check: true
