FROM golang:alpine

WORKDIR /opt/app
EXPOSE 3000

ENV GO111MODULE="on"
ENV GOOS="linux"
ENV CGO_ENABLED=0

HEALTHCHECK --interval=10s --timeout=5s --retries=5 CMD curl -f -o /dev/null http://127.0.0.1:3000/ping || exit 1

ENTRYPOINT ["reflex", "-d", "fancy", "-c", "./build/dev/reflex.conf"]

RUN apk update && \
  apk add --no-cache ca-certificates git && \
  update-ca-certificates && \
  go install github.com/go-delve/delve/cmd/dlv@latest && \
  go install github.com/cespare/reflex@latest
