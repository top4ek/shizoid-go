FROM golang:1.26-alpine

WORKDIR /opt/app
EXPOSE 3000

ENV GO111MODULE="on"
ENV GOOS="linux"
ENV CGO_ENABLED=0

ENTRYPOINT ["sh", "-c", "test -f build/dev/config.yaml || cp build/dev/config.yaml-example build/dev/config.yaml; exec reflex -d fancy -c ./build/dev/reflex.conf"]

RUN apk update && \
  apk add --no-cache ca-certificates git && \
  update-ca-certificates && \
  go install github.com/go-delve/delve/cmd/dlv@latest && \
  go install github.com/cespare/reflex@latest
